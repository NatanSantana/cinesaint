// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum StatusIngresso {
    VALIDO
    UTILIZADO
}

enum Roles {
    ADM
    USER
}

enum StatusSessao {
  ATIVO
  INATIVO
}

enum Tiers {
    COMUM 
    IMERSIVO 
    DELUX 
    IMAX
    ESTUDANTIL
    
}

enum StatusCadeira {
    MANUTENCAO
    LIVRE
}


model Produtos {
  idProduto   Int       @id @default(autoincrement())
  nome        String    @unique
  categoria   String
  valor       Int

  produtosComprados   ProdutosComprados[]


  @@map("produtos")
}

model ProdutosComprados {
  idProdutoComprado      Int        @id @default(autoincrement())

  idProduto              Int
  produtos               Produtos   @relation(fields: [idProduto], references: [idProduto])

  cpf                   String? 

  @@map("produtosComprados")

}


model Salas {
  idSalas  Int    @id @default(autoincrement())
  numero   Int    @unique
  tierSala Tiers
  qtdeLimiteAssentos Int 

  sessoes Sessao[]

  assentos Assentos[]

  ingressosComprados IngressosComprados[]

  @@map("salas")
}

model Assentos {
  idAssentos    Int             @id @default(autoincrement())
  identificacao String          @unique
  statusCadeira StatusCadeira   @default(LIVRE)

  idSala Int
  sala   Salas           @relation(fields: [idSala], references: [idSalas])


  ingressosComprados IngressosComprados[]

  assentosOcupados   AssentosOcupados[]

  @@map("assentos")
}

model AssentosOcupados {
  idAssentoOcupado  Int         @id @default(autoincrement())

  idAssento         Int
  assentos          Assentos    @relation(fields: [idAssento], references: [idAssentos])

  idSessao          Int
  sessoes           Sessao      @relation(fields: [idSessao], references: [idSessao])

  @@map("assentosOcupados")
}

model Ingressos {
  idIngresso Int @id @default(autoincrement())
  valor Int
  tiers Tiers

  ingressosComprados IngressosComprados[]

  @@map("ingressos")
}


model IngressosComprados {
  idIngressoComprado  Int @id @default(autoincrement())

  idSala      Int
  sala        Salas       @relation(fields: [idSala], references: [idSalas])

  idFilme     Int
  filme       Filme       @relation(fields: [idFilme], references: [idFilme])

  idSessao    Int
  sessoes     Sessao      @relation(fields: [idSessao], references: [idSessao])

  idIngresso Int
  ingressos  Ingressos    @relation(fields: [idIngresso], references: [idIngresso]) 

  idAssento Int
  assentos  Assentos      @relation(fields: [idAssento], references: [idAssentos])

  status      StatusIngresso

  cpf         String

  @@map("ingressosComprados")

}

model Sessao {
  idSessao    Int             @id @default(autoincrement())
  dataSessao  DateTime

  idSala      Int
  sala        Salas           @relation(fields: [idSala], references: [idSalas])  

  idFilme      Int
  filme        Filme          @relation(fields: [idFilme], references: [idFilme])

  statusSessao StatusSessao   @default(ATIVO)

  ingressosComprados IngressosComprados[]

  assentosOcupados AssentosOcupados[]

  @@map("sessoes")
}

model Filme {
  idFilme                 Int       @id @default(autoincrement())
  nome                    String    @unique
  categoria               String
  classificacaoIndicativa Int
  minutosFilme            Int       @default(60)
  lancamento              DateTime  

  sessoes Sessao[]

  ingressosComprados IngressosComprados[]

  @@map("filmes")


  
}


model Users {
    idUser          Int     @id @default(autoincrement())
    nome            String
    email           String  @unique
    senha           String
    cpf             String  @unique
    dataNascimento  DateTime
    role            Roles   @default(USER)
  }

model ResetPassword {
  id            Int     @id @default(autoincrement())
  token         String  @unique
  email         String
  dataExpiracao DateTime
}